# Database Railway PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Sicurezza JWT — OBBLIGATORIA in produzione
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Durata token (default: access=60min, refresh=30giorni)
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# REFRESH_TOKEN_EXPIRE_DAYS=30

# Ambiente (development|production) — in production SECRET_KEY è obbligatoria
ENVIRONMENT=production

# API Keys AI (opzionali — servono per trascrizioni e AI)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# CORS — lista domini separati da virgola (no spazi)
# Esempio: https://steelex.railway.app,https://steelex.vercel.app
CORS_ORIGINS=https://tuo-frontend.railway.app

# Cloudflare R2 (opzionale — se non configurato usa filesystem locale)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=steelex-cantieri
R2_PUBLIC_URL=
