# Database Railway PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Sicurezza JWT — genera con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-questa-chiave-segreta-in-produzione

# API Keys AI (opzionali — servono per trascrizioni e AI)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# CORS — in produzione metti l'URL del frontend
CORS_ORIGINS=http://localhost:3000,https://tuo-frontend.railway.app
