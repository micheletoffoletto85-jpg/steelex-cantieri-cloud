{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://steelex-cantieri-cloud-production.up.railway.app/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://steelex-cantieri-cloud-production.up.railway.app/uploads/:path*"
    },
    {
      "source": "/((?!api/|uploads/).*)",
      "destination": "/index.html"
    }
  ]
}
